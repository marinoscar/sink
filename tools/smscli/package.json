{
  "name": "@enterprise/smscli",
  "version": "2026.3.1",
  "description": "AI-agent-friendly CLI for reading SMS messages and extracting OTP codes from the Sink API",
  "type": "module",
  "main": "dist/index.js",
  "bin": {
    "smscli": "./bin/smscli.js"
  },
  "scripts": {
    "build": "tsc",
    "dev": "tsc --watch",
    "start": "node bin/smscli.js",
    "clean": "rimraf dist",
    "test": "cross-env NODE_OPTIONS=--experimental-vm-modules jest",
    "test:watch": "cross-env NODE_OPTIONS=--experimental-vm-modules jest --watch",
    "test:cov": "cross-env NODE_OPTIONS=--experimental-vm-modules jest --coverage",
    "typecheck": "tsc --noEmit"
  },
  "keywords": [
    "cli",
    "sms",
    "otp",
    "ai-agent",
    "automation"
  ],
  "author": "",
  "license": "MIT",
  "dependencies": {
    "chalk": "^5.3.0",
    "commander": "^12.1.0",
    "open": "^10.1.0"
  },
  "devDependencies": {
    "@jest/globals": "^29.7.0",
    "@types/node": "^20.14.0",
    "cross-env": "^10.1.0",
    "jest": "^29.7.0",
    "rimraf": "^6.1.3",
    "ts-jest": "^29.1.1",
    "typescript": "^5.4.5"
  },
  "engines": {
    "node": ">=18.0.0"
  }
}
